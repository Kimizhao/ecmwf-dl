# ECMWF-DL 环境变量配置文件
# 复制此文件为 .env 并根据需要修改配置

# 时区设置
TZ=Asia/Shanghai

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 下载间隔（秒）- 用于定时下载
DOWNLOAD_INTERVAL=3600

# ECMWF API 配置（如果需要）
# ECMWF_API_URL=https://api.ecmwf.int/v1
# ECMWF_API_KEY=your_api_key_here

# 数据下载配置
# 默认下载日期（留空使用当天）
DEFAULT_DATE=
# 默认下载时间（UTC）
DEFAULT_TIME=00
# 默认预报步长
DEFAULT_STEP=0

# 文件存储配置
DATA_DIR=/app/data
ECMWF_DATA_DIR=/app/ecmwf_data
LOG_DIR=/app/logs

# 数据库配置（可选）
# POSTGRES_DB=ecmwf
# POSTGRES_USER=ecmwf
# POSTGRES_PASSWORD=changeme
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# Redis 配置（可选）
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0

# 网络配置
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1

# 资源限制
MAX_CONCURRENT_DOWNLOADS=2
MAX_MEMORY_USAGE=2G

# 重试配置
MAX_RETRIES=3
RETRY_DELAY=30

# 通知配置（可选）
# EMAIL_ENABLED=false
# EMAIL_SMTP_SERVER=smtp.example.com
# EMAIL_SMTP_PORT=587
# EMAIL_USERNAME=your_email@example.com
# EMAIL_PASSWORD=your_password
# EMAIL_TO=notify@example.com

# 监控配置（可选）
# METRICS_ENABLED=false
# METRICS_PORT=9090

# 清理配置
# AUTO_CLEANUP_ENABLED=true
# CLEANUP_OLDER_THAN_DAYS=7